{
    "version": "2.0.0",
    "configurations": [
        
        {
            "type": "antlr-debug",
            "request": "launch",
            "name": "Debug Current Grammar",
            "grammar": "${file}",
            "input": "input.txt",
            "visualParseTree": true
        },
    {
    "name": "Debug ANTLR4 grammar",
